---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import BentoHero from '@/components/BentoHero.astro';
import About from '@/components/About.astro';
import WorkTable from '@/components/WorkTable.astro';
import Writeups from '@/components/Writeups.astro';
import Skills from '@/components/Skills.astro';
import Contact from '@/components/Contact.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
---

<BaseLayout>
  <Nav />
  <main id="main">
    <BentoHero />
    <div class="reveal"><About /></div>
    <div class="reveal"><WorkTable /></div>
    <div class="reveal"><Writeups /></div>
    <div class="reveal"><Skills /></div>
    <div class="reveal"><Contact /></div>
  </main>
  <Footer />
  <Terminal />
</BaseLayout>
