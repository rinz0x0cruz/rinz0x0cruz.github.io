---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/PortfolioHeader.astro";
import ProfileIntro from "@/components/ProfileIntro.astro";
import AchievementRail from "@/components/AchievementRail.astro";
import ProjectCinema from "@/components/ProjectCinema.astro";
import ProjectIndex from "@/components/ProjectIndex.astro";
import ResearchCasework from "@/components/ResearchCasework.astro";
import AboutCompact from "@/components/AboutCompact.astro";
import TrajectoryProfiles from "@/components/TrajectoryProfiles.astro";
import WritingContact from "@/components/WritingContact.astro";
import Footer from "@/components/Footer.astro";
import Terminal from "@/components/Terminal.astro";

const homepageSections = [
  ProfileIntro,
  AchievementRail,
  ProjectCinema,
  ProjectIndex,
  ResearchCasework,
  AboutCompact,
  TrajectoryProfiles,
  WritingContact,
] as const;
const [publishedWork, publishedWriteups] = await Promise.all([
  getCollection('work', ({ data }) => !data.draft),
  getCollection('writeups', ({ data }) => !data.draft),
]);
const profileHasPart = [
  ...publishedWork.map((entry) => `/work/${entry.id}/`),
  ...publishedWriteups.map((entry) => `/writeups/${entry.id}/`),
];
---

<BaseLayout profilePage profileHasPart={profileHasPart}>
  <Nav />
  <main id="main">
    {homepageSections.map((Section) => <Section />)}
  </main>
  <Footer />
  <Terminal />
</BaseLayout>
