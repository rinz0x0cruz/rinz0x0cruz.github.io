---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/PortfolioHeader.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
---

<BaseLayout title="404 · not found" noindex>
  <Nav />
  <main id="main" class="section">
    <div class="container e404">
      <p class="prompt mono">Route exception · {Astro.url.pathname}</p>
      <h1>404</h1>
      <p class="msg">This path went dark. Either it moved, or it was never part of the case file.</p>
      <a class="btn btn-primary" href="/">Back home</a>
    </div>
  </main>
  <Footer />
  <Terminal />
</BaseLayout>

<style>
  main { min-height: calc(100svh - var(--nav-h)); display: grid; align-items: center; }
  .e404 { max-width: 760px; }
  .prompt { color: var(--cp-accent); font-size: 0.72rem; text-transform: uppercase; }
  h1 {
    font-size: clamp(7rem, 26vw, 15rem);
    line-height: 0.8;
    margin: 26px 0 30px;
    color: var(--cp-text);
  }
  .msg { max-width: 44ch; color: var(--cp-text-soft); margin-bottom: 28px; font-size: 1.05rem; }
</style>
