---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/PortfolioHeader.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
import { formatDate, isoDate } from '@/utils/format';

export const getStaticPaths = (async () => {
  const writeups = (await getCollection('writeups')).filter((w) => !w.data.draft);
  return writeups.map((w) => ({
    params: { slug: w.id },
    props: { writeup: w },
  }));
}) satisfies GetStaticPaths;

const { writeup } = Astro.props;
const { Content } = await render(writeup);
const { title, summary, date, tags } = writeup.data;
---

<BaseLayout
  title={title}
  description={summary}
  article
  publishedTime={date.toISOString()}
  articleTags={tags}
>
  <Nav />
  <main id="main" class="section">
    <article class="container article">
      <a class="back mono" href="/writeups">← Blogs</a>
      <header class="wh">
        <time class="mono" datetime={isoDate(date)}>{formatDate(date)}</time>
        <h1>{title}</h1>
        <ul class="tags mono">
          {tags.map((t) => <li>#{t}</li>)}
        </ul>
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
  <Terminal />
</BaseLayout>

<style>
  main { background: var(--cp-bg-elevated); }
  .article { max-width: 900px; }
  .back {
    display: inline-block;
    font-size: 0.72rem;
    color: var(--cp-accent);
    margin-bottom: clamp(44px, 7vw, 72px);
    text-transform: uppercase;
  }
  .back:hover { color: var(--cp-accent-hover); }
  .wh { max-width: 820px; margin-bottom: clamp(44px, 8vw, 72px); padding-bottom: 32px; border-bottom: 1px solid var(--cp-border-strong); }
  .wh time { font-size: 0.72rem; color: var(--cp-text-muted); text-transform: uppercase; }
  .wh h1 {
    max-width: 15ch;
    font-size: clamp(2.8rem, 7vw, 5.6rem);
    margin: 16px 0 24px;
    line-height: 0.98;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .tags li { font-size: 0.7rem; color: var(--cp-accent); text-transform: uppercase; }
  .prose { margin-inline: auto; }
</style>
