---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/PortfolioHeader.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
import { formatDate, isoDate } from '@/utils/format';

export const getStaticPaths = (async () => {
  const writeups = (await getCollection('writeups')).filter((w) => !w.data.draft);
  return writeups.map((w) => ({
    params: { slug: w.id },
    props: { writeup: w },
  }));
}) satisfies GetStaticPaths;

const { writeup } = Astro.props;
const { Content } = await render(writeup);
const { title, summary, date, updated, snapshotDate, sources, tags } = writeup.data;
const socialImage = `/social/writeups/${writeup.id}.png`;
const socialImageAlt = `Social preview for ${title} with an ExploitRank dashboard.`;
---

<BaseLayout
  title={title}
  description={summary}
  image={socialImage}
  imageAlt={socialImageAlt}
  article
  publishedTime={date.toISOString()}
  modifiedTime={updated?.toISOString()}
  articleTags={tags}
  articleSnapshotTime={snapshotDate.toISOString()}
  articleSources={sources}
>
  <Nav />
  <main id="main" class="section">
    <article class="container article">
      <a class="back mono" href="/writeups">← Blogs</a>
      <header class="wh">
        <p class="article-dates mono">
          <time datetime={isoDate(date)}>Published {formatDate(date)}</time>
          {updated && <time datetime={isoDate(updated)}>Updated {formatDate(updated)}</time>}
          <time datetime={isoDate(snapshotDate)}>Evidence snapshot {formatDate(snapshotDate)}</time>
        </p>
        <h1>{title}</h1>
        <ul class="tags mono">
          {tags.map((t) => <li>#{t}</li>)}
        </ul>
      </header>
      <details class="source-ledger">
        <summary class="mono">Evidence sources · {sources.length}</summary>
        <ul>
          {sources.map((source) => (
            <li>
              <a href={source.url} target="_blank" rel="noreferrer">{source.label} ↗</a>
              <time class="mono" datetime={isoDate(source.accessed)}>Accessed {formatDate(source.accessed)}</time>
            </li>
          ))}
        </ul>
      </details>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
  <Terminal />
</BaseLayout>

<style>
  main { background: var(--cp-bg-elevated); }
  .article { max-width: 900px; }
  .back {
    display: inline-block;
    font-size: 0.72rem;
    color: var(--cp-accent);
    margin-bottom: clamp(44px, 7vw, 72px);
    text-transform: uppercase;
  }
  .back:hover { color: var(--cp-accent-hover); }
  .wh { max-width: 820px; margin-bottom: clamp(44px, 8vw, 72px); padding-bottom: 32px; border-bottom: 1px solid var(--cp-border-strong); }
  .article-dates { display: flex; flex-wrap: wrap; gap: 10px 24px; font-size: 0.72rem; color: var(--cp-text-muted); text-transform: uppercase; }
  .source-ledger { max-width: 760px; margin: -34px auto 52px; border-block: 1px solid var(--cp-border); padding-block: 14px; }
  .source-ledger summary { color: var(--cp-accent); font-size: var(--type-label); font-weight: 700; text-transform: uppercase; cursor: pointer; }
  .source-ledger ul { display: grid; gap: 12px; margin-top: 16px; }
  .source-ledger li { display: flex; justify-content: space-between; gap: 20px; color: var(--cp-text-soft); font-size: var(--type-small); }
  .source-ledger time { flex: none; color: var(--cp-text-muted); font-size: var(--type-label); text-transform: uppercase; }
  .wh h1 {
    max-width: 15ch;
    font-size: clamp(2.8rem, 7vw, 5.6rem);
    margin: 16px 0 24px;
    line-height: 0.98;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .tags li { font-size: 0.7rem; color: var(--cp-accent); text-transform: uppercase; }
  .prose { margin-inline: auto; }
  @media (max-width: 620px) {
    .source-ledger li { align-items: flex-start; flex-direction: column; gap: 4px; }
  }
</style>
