---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/PortfolioHeader.astro';
import Footer from '@/components/Footer.astro';
import Terminal from '@/components/Terminal.astro';
import { formatDate, isoDate } from '@/utils/format';

const writeups = (await getCollection('writeups'))
  .filter((w) => !w.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Blogs"
  description="Evidence-led analysis from ExploitRank vulnerability and threat-intelligence data."
>
  <Nav />
  <main id="main" class="section">
    <div class="container">
      <p class="section-label">Research blog · Archive</p>
      <h1 class="page-title">Signals, decisions, and the evidence between them.</h1>
      <p class="page-sub">
        Current analyses built directly from ExploitRank's published
        vulnerability, actor, technique, and ransomware snapshots.
      </p>

      <ul class="wlist">
        {
          writeups.map((w, index) => (
            <li>
              <a href={`/writeups/${w.id}`}>
                <span class="index mono">{String(index + 1).padStart(2, '0')}</span>
                <div class="body">
                  <time class="mono" datetime={isoDate(w.data.date)}>{formatDate(w.data.date)}</time>
                  <h2>{w.data.title}</h2>
                  <p>{w.data.summary}</p>
                  <ul class="tags mono">
                    {w.data.tags.map((t) => (
                      <li>#{t}</li>
                    ))}
                  </ul>
                </div>
                <span class="arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </main>
  <Footer />
  <Terminal />
</BaseLayout>

<style>
  .page-title {
    max-width: 14ch;
    font-size: clamp(3rem, 7vw, 6rem);
    margin-bottom: 24px;
  }
  .page-sub {
    color: var(--fg-dim);
    max-width: 60ch;
    margin-bottom: clamp(56px, 9vw, 100px);
    font-size: 1.05rem;
  }
  .wlist { border-top: 1px solid var(--cp-border-strong); }
  .wlist > li > a {
    display: grid;
    grid-template-columns: 54px 1fr auto;
    gap: clamp(18px, 4vw, 48px);
    align-items: start;
    padding: 30px 0;
    background: transparent;
    border-bottom: 1px solid var(--cp-border);
    color: var(--fg);
    transition: padding 0.2s var(--ease), background 0.2s var(--ease);
  }
  .wlist > li > a:hover {
    padding-inline: 14px;
    background: var(--cp-accent-soft);
  }
  .index { color: var(--cp-text-muted); font-size: 0.72rem; }
  .wlist time {
    display: block;
    font-size: 0.72rem;
    color: var(--cp-text-muted);
    text-transform: uppercase;
  }
  .body h2 {
    font-size: clamp(1.35rem, 2.8vw, 2.2rem);
    margin: 8px 0 10px;
  }
  .wlist a:hover .body h2 { color: var(--cp-accent); }
  .body p {
    color: var(--fg-dim);
    font-size: 0.92rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 10px;
  }
  .tags li { font-size: 0.7rem; color: var(--cp-accent); text-transform: uppercase; }
  .arrow { color: var(--cp-accent); font-size: 1.2rem; }

  @media (max-width: 640px) {
    .page-title { max-width: 12ch; font-size: 2.65rem; line-height: .98; }
    .wlist > li > a { grid-template-columns: 34px 1fr; gap: 10px; }
    .arrow { display: none; }
  }
</style>
