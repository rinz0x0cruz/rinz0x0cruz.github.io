---
import '@fontsource/barlow-semi-condensed/latin-600.css';
import '@fontsource/barlow-semi-condensed/latin-700.css';
import '@fontsource-variable/ibm-plex-sans/wght.css';
import '@fontsource/ibm-plex-mono/latin-400.css';
import '@fontsource/ibm-plex-mono/latin-700.css';
import '@/styles/global.css';
import MotionLayer from '@/components/MotionLayer.astro';
import { site } from '@/data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishedTime?: string;
  articleTags?: readonly string[];
  noindex?: boolean;
}

const {
  title,
  description = site.tagline,
  image = site.ogImage,
  article = false,
  publishedTime,
  articleTags = [],
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.role}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(image, Astro.site).href;

const personSchema = {
  '@type': 'Person',
  '@id': `${site.url}/#person`,
  name: site.name,
  alternateName: site.handle,
  jobTitle: site.role,
  url: site.url,
  email: `mailto:${site.email}`,
  sameAs: site.socials.filter((s) => s.icon !== 'email').map((s) => s.url),
  knowsAbout: [...site.knowsAbout],
};
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    personSchema,
    ...(article
      ? [
          {
            '@type': 'BlogPosting',
            headline: title,
            description,
            datePublished: publishedTime,
            mainEntityOfPage: canonicalURL,
            image: ogImageURL,
            keywords: [...articleTags],
            author: { '@id': `${site.url}/#person` },
          },
        ]
      : []),
  ],
};
const structuredDataJson = JSON.stringify(structuredData).replace(/</g, '\\u003c');
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (() => {
        const param = new URLSearchParams(window.location.search).get("scoutTheme");
        const theme =
          param || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta name="theme-color" content="#f7f4ef" />
    <meta name="color-scheme" content="light dark" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} · blogs`}
      href={new URL('/rss.xml', Astro.site)}
    />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <script is:inline type="application/ld+json" set:html={structuredDataJson}></script>

  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <MotionLayer />
    <slot />
  </body>
</html>
