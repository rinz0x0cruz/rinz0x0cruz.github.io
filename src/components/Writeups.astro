---
import { getCollection } from 'astro:content';
import WriteupCard from './WriteupCard.astro';

const all = (await getCollection('writeups'))
  .filter((w) => !w.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latest = all.slice(0, 3);
---

{
  latest.length > 0 && (
    <section id="writeups" class="section writeups">
      <div class="container">
        <p class="section-label">ls writeups/</p>
        <div class="wgrid">
          {latest.map((w) => (
            <WriteupCard writeup={w} />
          ))}
        </div>
        {all.length > latest.length && (
          <a class="all mono" href="/writeups">
            all writeups →
          </a>
        )}
      </div>
    </section>
  )
}

<style>
  .wgrid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
  }
  .all {
    display: inline-block;
    margin-top: 26px;
    font-size: 0.9rem;
    color: var(--blue);
  }
  .all:hover { color: var(--cyan); }
</style>
