---
import SocialLinks from './SocialLinks.astro';
import { site } from '@/data/site';
---

<section id="contact" class="section contact">
  <div class="container contact-inner">
    <p class="section-label">Uplink // contact</p>
    <h2>Say hi (or send a sample).</h2>
    <p class="lead">
      Hiring, consulting, or just stuck on a &ldquo;what is this binary doing&rdquo;
      question? I&rsquo;m all ears. Drop a line and I&rsquo;ll get back to you
      faster than an EDR alert. Résumé on request.
    </p>
    <div class="contact-cta">
      <a class="btn btn-primary" href={`mailto:${site.email}`}>Email me</a>
      <a class="btn" href={site.resumeRequest}>Request résumé</a>
    </div>
    <SocialLinks variant="row" />
  </div>
</section>

<style>
  .contact-inner { max-width: 720px; }
  h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-bottom: 14px;
  }
  .lead {
    font-size: 1.08rem;
    color: var(--fg-dim);
    max-width: 56ch;
  }
  .contact-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 26px 0 30px;
  }
</style>
