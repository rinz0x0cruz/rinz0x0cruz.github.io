---
import LottieSkull from './LottieSkull.astro';
import { site } from '@/data/site';

const session = '0x0';
---

<section id="top" class="hero">
  <div class="container">
    <div class="frame">
      <span class="scan" aria-hidden="true"></span>
      <div class="hbar mono">
        <span><span class="g">▸ GRID ACCESS //</span> {site.host}<span class="cursor" aria-hidden="true"></span></span>
        <span class="leds">
          SESSION {session} · CAFFEINATED
          <i class="led" aria-hidden="true"></i><i class="led b" aria-hidden="true"></i><i class="led p" aria-hidden="true"></i>
        </span>
      </div>

      <div class="id">
        <div class="reticle" aria-hidden="true">
          <LottieSkull size={116} />
        </div>
        <div class="idc">
          <h1>{site.name}</h1>
          <p class="role mono">{site.role} &amp; Reverse Engineer <b>· @{site.handle}</b></p>
          <p class="one">
            I take malware apart to see what makes it tick, rank the CVEs actually
            worth losing sleep over, and hunt the operators behind the keyboard.
          </p>
          <div class="cta">
            <a class="btn btn-primary" href="#work">Engage ▸ work</a>
            <a class="btn" href={site.resumeUrl} download>Download résumé</a>
            <button class="btn" type="button" data-open-terminal>./terminal</button>
          </div>
          {
            site.availableForWork && (
              <p class="avail mono"><span class="dot" aria-hidden="true" /> {site.availabilityNote}</p>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero { padding-top: clamp(24px, 4vw, 40px); padding-bottom: clamp(6px, 2vw, 16px); }

  .frame {
    position: relative;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: clamp(22px, 3.5vw, 34px);
    background: linear-gradient(180deg, rgba(31, 35, 53, 0.6), rgba(26, 27, 38, 0.5));
  }
  .frame::before, .frame::after {
    content: ''; position: absolute; width: 22px; height: 22px; border: 2px solid var(--cyan);
    animation: corner-pulse 3.2s ease-in-out infinite;
  }
  @keyframes corner-pulse { 0%, 100% { opacity: 0.55; } 50% { opacity: 1; } }
  .frame::before { top: -1px; left: -1px; border-right: 0; border-bottom: 0; box-shadow: -2px -2px 12px rgba(125, 207, 255, 0.35); }
  .frame::after { bottom: -1px; right: -1px; border-left: 0; border-top: 0; box-shadow: 2px 2px 12px rgba(125, 207, 255, 0.35); animation-delay: 1.6s; }

  .hbar {
    display: flex; justify-content: space-between; align-items: center; gap: 10px 16px; flex-wrap: wrap;
    font-size: 0.76rem; letter-spacing: 0.1em; color: var(--muted);
    border-bottom: 1px solid var(--border); padding-bottom: 14px;
  }
  .hbar .g { color: var(--cyan); }
  .leds { display: inline-flex; gap: 8px; align-items: center; }
  .led { width: 8px; height: 8px; border-radius: 50%; background: var(--cyan); box-shadow: 0 0 8px var(--cyan); animation: led-blink 1.8s ease-in-out infinite; }
  .led.b { background: var(--blue); box-shadow: 0 0 8px var(--blue); animation-delay: 0.3s; }
  .led.p { background: var(--purple); box-shadow: 0 0 8px var(--purple); animation-delay: 0.6s; }
  @keyframes led-blink { 0%, 100% { opacity: 0.35; } 50% { opacity: 1; } }

  .scan {
    position: absolute; left: 0; right: 0; top: 0; height: 2px; pointer-events: none; z-index: 1;
    background: linear-gradient(90deg, transparent, rgba(125, 207, 255, 0.5), transparent);
    box-shadow: 0 0 12px rgba(125, 207, 255, 0.4); animation: scan-sweep 6s linear infinite;
  }
  @keyframes scan-sweep { 0% { top: 0; opacity: 0; } 12% { opacity: 1; } 88% { opacity: 1; } 100% { top: calc(100% - 2px); opacity: 0; } }
  .cursor {
    display: inline-block; width: 8px; height: 1em; margin-left: 5px; vertical-align: -2px;
    background: var(--cyan); box-shadow: 0 0 6px var(--cyan); animation: cursor-blink 1.1s step-end infinite;
  }
  @keyframes cursor-blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }

  .id { display: flex; gap: clamp(24px, 4vw, 42px); align-items: center; padding: clamp(24px, 4vw, 36px) 0 8px; }
  .reticle {
    width: 156px; height: 156px; flex: none; border-radius: 50%;
    border: 1px solid rgba(125, 207, 255, 0.45);
    display: grid; place-items: center; position: relative;
    box-shadow: 0 0 28px rgba(125, 207, 255, 0.16), inset 0 0 28px rgba(125, 207, 255, 0.1);
    animation: reticle-glow 3.6s ease-in-out infinite;
  }
  @keyframes reticle-glow {
    0%, 100% { box-shadow: 0 0 24px rgba(125, 207, 255, 0.14), inset 0 0 24px rgba(125, 207, 255, 0.08); }
    50% { box-shadow: 0 0 36px rgba(125, 207, 255, 0.3), inset 0 0 32px rgba(125, 207, 255, 0.16); }
  }
  .reticle::before {
    content: ''; position: absolute; inset: 11px; border-radius: 50%;
    border: 1px dashed rgba(122, 162, 247, 0.5); animation: reticle-spin 16s linear infinite;
  }
  .reticle::after {
    content: ''; position: absolute; inset: -7px; border-radius: 50%;
    border: 1px dotted rgba(187, 154, 247, 0.4); animation: reticle-spin 26s linear infinite reverse;
  }
  @keyframes reticle-spin { to { transform: rotate(360deg); } }

  .idc h1 {
    font-size: clamp(2.1rem, 4.6vw, 3rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.02;
    background: linear-gradient(92deg, var(--fg), var(--cyan));
    -webkit-background-clip: text; background-clip: text; color: transparent;
    animation: name-glitch 7s steps(1) infinite;
  }
  @keyframes name-glitch {
    0%, 94%, 96.5%, 100% { transform: none; filter: none; clip-path: none; }
    94.5% { transform: translateX(-2px); filter: drop-shadow(2px 0 var(--red)) drop-shadow(-2px 0 var(--cyan)); }
    95% { clip-path: inset(18% 0 52% 0); transform: translateX(3px); }
    95.5% { clip-path: inset(62% 0 8% 0); transform: translateX(-3px); }
    96% { clip-path: inset(38% 0 30% 0); transform: translateX(2px); filter: drop-shadow(-2px 0 var(--red)) drop-shadow(2px 0 var(--cyan)); }
  }
  .idc .role { color: var(--fg); margin-top: 8px; }
  .idc .role b { color: var(--purple); font-weight: 400; }
  .idc .one { color: var(--muted); margin-top: 12px; max-width: 54ch; font-size: 0.96rem; }
  .idc .cta { margin-top: 20px; display: flex; gap: 10px; flex-wrap: wrap; }

  .avail { display: inline-flex; align-items: center; gap: 9px; color: var(--cyan); margin-top: 16px; font-size: 0.85rem; }
  .avail .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--cyan); box-shadow: 0 0 10px var(--cyan); animation: hud-pulse 2s infinite; }
  @keyframes hud-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  @media (max-width: 620px) {
    .id { flex-direction: column; align-items: flex-start; }
  }
  @media (prefers-reduced-motion: reduce) {
    .reticle, .reticle::before, .reticle::after, .avail .dot, .led, .scan, .cursor,
    .frame::before, .frame::after, .idc h1 { animation: none; }
    .cursor { opacity: 1; }
  }
</style>
