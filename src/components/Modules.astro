---
import { projects } from '@/data/projects';

const status: Record<string, { label: string; cls: string }> = {
  live: { label: 'LIVE', cls: '' },
  active: { label: 'ACTIVE', cls: 'b' },
  research: { label: 'RESEARCH', cls: 'p' },
};
const sigs = ['0xA1', '0xB2', '0xC3', '0xD4', '0xE5', '0xF6', '0x07', '0x18'];
---

<section id="work" class="section work">
  <div class="container">
    <p class="section-label">Modules // selected work</p>

    <div class="mods">
      {
        projects.map((p, i) => (
          <a class="mod" href={p.links.live ?? p.links.repo} target="_blank" rel="noopener">
            <span class="corner" aria-hidden="true" />
            <div class="top">
              <span class="nm mono">{p.name}</span>
              <span class={`st mono ${status[p.status].cls}`}>
                <span class="d" aria-hidden="true" />
                {status[p.status].label}
              </span>
            </div>
            <p class="ds">{p.tagline}</p>
            <p class="tel mono">LANG: {p.stack.join('/').toUpperCase()} · SIG: {sigs[i]}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .mods { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .mod {
    position: relative; display: block; color: var(--fg);
    border: 1px solid var(--border); border-radius: 4px; padding: 17px 18px;
    background: rgba(31, 35, 53, 0.5);
    transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .corner {
    position: absolute; top: -1px; left: -1px; width: 12px; height: 12px;
    border-top: 2px solid var(--cyan); border-left: 2px solid var(--cyan);
  }
  .mod:hover { border-color: var(--blue); box-shadow: 0 0 18px rgba(122, 162, 247, 0.14); transform: translateY(-2px); }

  .top { display: flex; justify-content: space-between; align-items: center; gap: 10px; }
  .nm { font-weight: 700; color: var(--fg); }
  .st { font-size: 0.62rem; letter-spacing: 0.1em; color: var(--cyan); display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; }
  .st .d { width: 6px; height: 6px; border-radius: 50%; background: var(--cyan); box-shadow: 0 0 6px var(--cyan); animation: mod-led 2.4s ease-in-out infinite; }
  @keyframes mod-led { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
  .st.b { color: var(--blue); } .st.b .d { background: var(--blue); box-shadow: 0 0 6px var(--blue); }
  .st.p { color: var(--purple); } .st.p .d { background: var(--purple); box-shadow: 0 0 6px var(--purple); }

  .ds { color: var(--muted); font-size: 0.88rem; margin-top: 10px; }
  .tel { color: var(--muted); font-size: 0.66rem; margin-top: 12px; letter-spacing: 0.06em; }

  @media (max-width: 820px) { .mods { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .mods { grid-template-columns: 1fr; } }
  @media (prefers-reduced-motion: reduce) { .st .d { animation: none; } }
</style>
