---
import { site } from '@/data/site';
const year = new Date().getFullYear();
const repo = `https://github.com/${site.handle}/${site.handle}.github.io`;
---

<footer class="footer">
  <div class="container foot-inner">
    <div><strong>{site.name}</strong><span class="mono">Security research · @{site.handle}</span></div>
    <p class="mono">© {year} · <a href="/privacy/">Privacy</a> · <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> · <a href={repo} target="_blank" rel="noopener">Source</a></p>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--cp-border);
    background: var(--cp-bg);
  }
  .footer::before {
    content: '';
    position: absolute;
    top: -1px;
    left: -22%;
    width: 22%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cp-accent), transparent);
    animation: footer-signal 5.8s var(--ease) infinite;
  }
  .foot-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: 34px;
    padding-bottom: 42px;
    font-size: 0.74rem;
  }
  .foot-inner > div { display: grid; gap: 5px; }
  .foot-inner strong { color: var(--cp-text); }
  .foot-inner span,
  .foot-inner p { color: var(--cp-text-muted); }
  .foot-inner a { color: var(--cp-text-soft); }
  .foot-inner a:hover { color: var(--cp-accent); }
  @keyframes footer-signal { 0%, 18% { left: -22%; opacity: 0; } 30% { opacity: 1; } 70%, 100% { left: 105%; opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .footer::before { animation: none; } }
</style>
