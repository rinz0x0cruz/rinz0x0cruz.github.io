---
import { projects } from '@/data/projects';

const statusColor: Record<string, string> = {
  live: 'var(--cyan)',
  active: 'var(--blue)',
  research: 'var(--purple)',
};
const letters = ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'];
---

<section id="work" class="section work">
  <div class="container">
    <p class="section-label">Exhibits // selected work</p>

    <div class="exhibits">
      {
        projects.map((p, i) => (
          <article class="ex">
            <div class="ex-top">
              <span class="tag mono">EXHIBIT {letters[i]}</span>
              <span class="chip mono">
                <span class="d" style={`background:${statusColor[p.status]}`} aria-hidden="true" />
                {p.status}
              </span>
            </div>
            <h3 class="ex-name mono">{p.name}</h3>
            <p class="ex-stack mono">{p.stack.join(' · ')}</p>
            <p class="ex-desc">{p.tagline}</p>
            <div class="ex-links mono">
              {p.links.live && (
                <a href={p.links.live} target="_blank" rel="noopener">live ↗</a>
              )}
              {p.links.repo && (
                <a href={p.links.repo} target="_blank" rel="noopener">code ↗</a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .exhibits {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .ex {
    display: flex;
    flex-direction: column;
    padding: 22px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .ex:hover { border-color: var(--blue); transform: translateY(-3px); }

  .ex-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .tag {
    font-size: 0.64rem; letter-spacing: 0.16em; font-weight: 700;
    color: #14161f; background: var(--yellow); border-radius: 4px; padding: 3px 8px;
  }
  .chip {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.72rem; padding: 3px 10px; border-radius: 999px;
    border: 1px solid var(--border); color: var(--fg); text-transform: capitalize;
  }
  .chip .d { width: 7px; height: 7px; border-radius: 50%; }

  .ex-name { font-size: 1.2rem; font-weight: 700; color: var(--fg); }
  .ex-stack { color: var(--cyan); font-size: 0.8rem; margin-top: 2px; }
  .ex-desc { color: var(--muted); font-size: 0.92rem; margin-top: 12px; flex: 1; }
  .ex-links { margin-top: 16px; display: flex; gap: 14px; }
  .ex-links a { font-size: 0.82rem; color: var(--blue); }
  .ex-links a:hover { color: var(--cyan); }
</style>
