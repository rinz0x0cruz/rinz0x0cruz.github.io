---
import Icon from './Icon.astro';
import { site } from '@/data/site';

interface Props {
  variant?: 'row' | 'stack';
}
const { variant = 'row' } = Astro.props;
---

<ul class:list={['socials', variant]}>
  {
    site.socials.map((s) => (
      <li>
        <a
          class="social"
          href={s.url}
          rel={s.icon === 'email' ? undefined : 'me noopener'}
          target={s.icon === 'email' ? undefined : '_blank'}
          aria-label={s.name}
        >
          <Icon name={s.icon} size={18} />
          <span class="label">
            <span class="name">{s.name}</span>
            <span class="handle mono">{s.handle}</span>
          </span>
        </a>
      </li>
    ))
  }
</ul>

<style>
  .socials {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .socials.stack {
    flex-direction: column;
    gap: 10px;
  }
  .social {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    color: var(--fg);
    transition: border-color 0.18s var(--ease), transform 0.18s var(--ease), background 0.18s var(--ease);
  }
  .social:hover {
    border-color: var(--blue);
    background: rgba(122, 162, 247, 0.08);
    transform: translateY(-2px);
    color: var(--fg);
  }
  .social :global(svg) {
    color: var(--blue);
    flex-shrink: 0;
  }
  .social:hover :global(svg) {
    color: var(--cyan);
  }
  .label {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
  }
  .name {
    font-weight: 600;
    font-size: 0.95rem;
  }
  .handle {
    font-size: 0.78rem;
    color: var(--muted);
  }
  .row .social .label {
    /* compact chips in row mode */
  }
</style>
