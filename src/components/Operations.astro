---
// STAR operations record — quantified wins from the résumé (Situation/Task/Action
// in the brief, Result called out). Facts are from the résumé; nothing invented.
interface Op {
  id: string;
  cat: string;
  title: string;
  brief: string;
  result: string;
}
const ops: Op[] = [
  {
    id: 'OP-01', cat: 'NATION-STATE',
    title: 'Midnight Blizzard kill-chain reconstruction',
    brief:
      'Reconstructed the full kill chain of a nation-state (APT29 / Midnight Blizzard) intrusion that deployed INC ransomware, correlating endpoint and identity telemetry to trace the operator from credential theft through C2 to hands-on Rclone exfiltration across an on-prem to Entra pivot.',
    result: 'Delivered the IOC narrative that drove proactive containment.',
  },
  {
    id: 'OP-02', cat: 'DETECTION',
    title: 'Org-wide detection-accuracy program',
    brief:
      'Root-caused data-normalization and version-mapping defects across 10+ products (Adobe Acrobat, Teams, Telegram) and shipped 9 of 10 specs for data ingestion and normalization.',
    result: 'Cut false-positive incidents 47% (511 resolved).',
  },
  {
    id: 'OP-03', cat: 'THREAT HUNT',
    title: 'Turla APT threat hunt',
    brief:
      'Ran a Diamond Model threat hunt on the Turla APT and reverse-engineered 8 malware families (incl. Turla and Agent Tesla) via static/dynamic analysis, authoring YARA rules and automating VirusTotal feed analysis.',
    result: 'YARA rules yielded 50,000+ detections; triage went from ~2 hours to near real-time.',
  },
  {
    id: 'OP-04', cat: 'VULN INTEL',
    title: 'Emerging-threat CVE triage on high-severity on-call',
    brief:
      'Triaged emerging-threat CVEs end to end for severity, exposure, and detection coverage, including the actively-exploited CVE-2026-43600 kernel family and a nation-state Cisco ASA CVE (CVSS 9.9) missed because device discovery skipped OS-version normalization.',
    result: 'Carried 22 of 31 tracked CVEs to closure and shipped the fix that restored ASA coverage.',
  },
  {
    id: 'OP-05', cat: 'OSINT',
    title: 'Hacker4Justice suspect de-anonymization',
    brief:
      'Ran OSINT (alias/persona correlation, cross-source corroboration) on a CSAM-marketplace dataset of 4,800+ suspect credentials, de-anonymizing suspects from minimal selectors under OPSEC-aware source handling.',
    result: 'Reached a 23% positive-ID rate; the case has identified 44+ buyers and sellers.',
  },
];
---

<section id="ops" class="section ops-sec">
  <div class="container">
    <p class="section-label">STAR // operations record</p>

    <div class="ops">
      {
        ops.map((op) => (
          <article class="op">
            <div class="op-top">
              <span class="opid mono">{op.id}</span>
              <span class="opcat mono">{op.cat}</span>
            </div>
            <h3>{op.title}</h3>
            <p class="brief">{op.brief}</p>
            <p class="result mono"><span class="rlab">RESULT</span> {op.result}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .ops { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .op {
    position: relative; padding: 22px; border: 1px solid var(--border); border-radius: 4px;
    background: rgba(31, 35, 53, 0.5); transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .op::before { content: ''; position: absolute; top: -1px; left: -1px; width: 12px; height: 12px; border-top: 2px solid var(--cyan); border-left: 2px solid var(--cyan); }
  .op:hover { border-color: var(--blue); box-shadow: 0 0 18px rgba(122, 162, 247, 0.12); transform: translateY(-2px); }

  .op-top { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .opid { font-size: 0.64rem; letter-spacing: 0.14em; font-weight: 700; color: #0d1017; background: var(--cyan); border-radius: 4px; padding: 3px 8px; }
  .opcat { font-size: 0.62rem; letter-spacing: 0.16em; color: var(--purple); border: 1px solid var(--border); border-radius: 999px; padding: 2px 10px; }

  .op h3 { font-size: 1.08rem; color: var(--fg); line-height: 1.25; }
  .op .brief { color: var(--muted); font-size: 0.88rem; margin-top: 10px; line-height: 1.6; }
  .op .result { margin-top: 14px; padding-top: 12px; border-top: 1px dashed var(--border); color: var(--fg); font-size: 0.82rem; line-height: 1.5; }
  .op .rlab { color: var(--cyan); font-weight: 700; letter-spacing: 0.1em; margin-right: 8px; }

  @media (max-width: 820px) { .ops { grid-template-columns: 1fr; } }
</style>
