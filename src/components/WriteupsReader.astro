---
import { getCollection } from 'astro:content';
import { formatDate, isoDate } from '@/utils/format';

const writeups = (await getCollection('writeups'))
  .filter((w) => !w.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

{
  writeups.length > 0 && (
    <section id="writeups" class="section">
      <div class="container">
        <p class="section-label">Transmissions // writeups</p>

        <div class="reader" data-wreader>
          <aside class="wlist" data-wlist>
            {writeups.map((w, i) => (
              <button class:list={['witem', { active: i === 0 }]} type="button" data-slug={w.id}>
                <time class="wdt mono" datetime={isoDate(w.data.date)}>
                  {formatDate(w.data.date)}
                </time>
                <span class="wt">{w.data.title}</span>
                <span class="wsum">{w.data.summary}</span>
                <span class="wtags mono">
                  {w.data.tags.slice(0, 4).map((t) => <em>#{t}</em>)}
                </span>
              </button>
            ))}
            <a class="wall mono" href="/writeups">full archive &rarr;</a>
          </aside>

          <div class="viewer" data-wviewer>
            <div class="vbar mono">
              <span class="vlabel">&#9656; reading</span>
              <a class="vopen" data-wopen href="/writeups" target="_blank" rel="noopener">open &#8599;</a>
            </div>
            <header class="vhead" data-whead />
            <div class="vbody" data-wbody>
              <p class="wloading mono">Select a transmission.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  function initWReader() {
    document.querySelectorAll<HTMLElement>('[data-wreader]').forEach((root) => {
      if (root.dataset.init) return;
      root.dataset.init = '1';

      const list = root.querySelector('[data-wlist]');
      const viewer = root.querySelector('[data-wviewer]');
      const vhead = root.querySelector('[data-whead]');
      const vbody = root.querySelector('[data-wbody]');
      const openLink = root.querySelector('[data-wopen]') as HTMLAnchorElement | null;
      if (!list || !viewer || !vhead || !vbody) return;

      const cache = new Map<string, string>();
      const items = Array.from(list.querySelectorAll<HTMLButtonElement>('[data-slug]'));

      async function open(btn: HTMLButtonElement) {
        const slug = btn.dataset.slug!;
        const url = `/writeups/${slug}/`;
        items.forEach((b) => b.classList.toggle('active', b === btn));
        if (openLink) openLink.href = url;

        // Header, rebuilt from the list item (keeps the component's styles).
        vhead!.replaceChildren();
        const dt = btn.querySelector('.wdt');
        const tags = btn.querySelector('.wtags');
        if (dt) vhead!.appendChild(dt.cloneNode(true));
        const h = document.createElement('h3');
        h.textContent = btn.querySelector('.wt')?.textContent ?? '';
        vhead!.appendChild(h);
        if (tags) vhead!.appendChild(tags.cloneNode(true));

        vbody!.innerHTML = '<p class="wloading mono">fetching transmission&hellip;</p>';
        if (window.matchMedia('(max-width: 820px)').matches) {
          viewer!.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        try {
          let html = cache.get(slug);
          if (!html) {
            const res = await fetch(url);
            if (!res.ok) throw new Error(String(res.status));
            const doc = new DOMParser().parseFromString(await res.text(), 'text/html');
            const prose = doc.querySelector('.article .prose');
            html = prose ? prose.outerHTML : '<p>Content unavailable.</p>';
            cache.set(slug, html);
          }
          vbody!.innerHTML = html;
          vbody!.scrollTop = 0;
        } catch {
          vbody!.innerHTML =
            '<p class="werr mono">Transmission failed. Use &ldquo;open&rdquo; to read the full page.</p>';
        }
      }

      items.forEach((btn) => btn.addEventListener('click', () => open(btn)));
      if (items[0]) open(items[0]); // preload the newest
    });
  }

  initWReader();
  document.addEventListener('astro:page-load', initWReader);
</script>

<style>
  .reader { display: grid; grid-template-columns: minmax(240px, 320px) 1fr; gap: 18px; align-items: start; }

  .wlist { display: flex; flex-direction: column; gap: 10px; }
  .witem {
    text-align: left; display: grid; gap: 5px; padding: 14px 16px; position: relative;
    border: 1px solid var(--border); border-radius: 4px; background: rgba(31, 35, 53, 0.4);
    color: var(--fg); cursor: pointer; transition: border-color 0.2s var(--ease), background 0.2s var(--ease);
  }
  .witem::before {
    content: ''; position: absolute; top: -1px; left: -1px; width: 10px; height: 10px;
    border-top: 2px solid transparent; border-left: 2px solid transparent; transition: border-color 0.2s var(--ease);
  }
  .witem:hover { border-color: var(--blue); }
  .witem.active { border-color: var(--cyan); background: rgba(125, 207, 255, 0.06); }
  .witem.active::before { border-top-color: var(--cyan); border-left-color: var(--cyan); }
  .wdt { font-size: 0.7rem; color: var(--cyan); }
  .wt { font-weight: 700; color: var(--fg); font-size: 0.98rem; line-height: 1.3; }
  .wsum { font-size: 0.82rem; color: var(--muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .wtags { font-size: 0.66rem; color: var(--purple); display: flex; gap: 8px; flex-wrap: wrap; }
  .wtags em { font-style: normal; }
  .wall { font-size: 0.8rem; color: var(--blue); padding: 8px 4px 0; }
  .wall:hover { color: var(--cyan); }

  .viewer { border: 1px solid var(--border); border-radius: 4px; background: rgba(20, 22, 31, 0.5); display: flex; flex-direction: column; max-height: 560px; overflow: hidden; position: relative; }
  .viewer::before { content: ''; position: absolute; top: -1px; right: -1px; width: 12px; height: 12px; border-top: 2px solid var(--cyan); border-right: 2px solid var(--cyan); }
  .vbar { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 10px 16px; border-bottom: 1px solid var(--border); font-size: 0.74rem; letter-spacing: 0.1em; color: var(--muted); background: rgba(125, 207, 255, 0.03); }
  .vbar .vlabel { color: var(--cyan); }
  .vbar .vopen { color: var(--blue); }
  .vbar .vopen:hover { color: var(--cyan); }
  .vhead { padding: 20px 22px 0; }
  .vhead h3 { font-size: 1.4rem; color: var(--fg); margin: 8px 0 10px; line-height: 1.2; }
  .vhead .wtags { font-size: 0.72rem; gap: 12px; }
  .vbody { padding: 14px 22px 24px; overflow-y: auto; }
  .wloading { color: var(--muted); }
  .werr { color: var(--red); }

  @media (max-width: 820px) {
    .reader { grid-template-columns: 1fr; }
    .viewer { max-height: none; }
  }
</style>
