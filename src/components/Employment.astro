---
// Employment / service record — a HUD "hall of fame" with employer logos.
// Roles sourced from the résumé.

// Every role held, earliest first. Drives the computed experience readout.
const roles = [
  { org: 'Microsoft', start: new Date(2024, 4, 1), end: new Date(2024, 6, 31) }, // Security Researcher Intern
  { org: 'Microsoft', start: new Date(2025, 5, 1), end: null }, // Security Researcher (current)
  { org: 'Hacker4Justice', start: new Date(2025, 5, 1), end: new Date(2026, 5, 30) }, // Volunteer OSINT
];

// Career span: earliest role start -> today (auto-updates as the current role runs on).
const careerStart = new Date(Math.min(...roles.map((r) => r.start.getTime())));
const expYears = (Date.now() - careerStart.getTime()) / (365.25 * 24 * 60 * 60 * 1000);
const expDisplay = expYears.toFixed(1);
const startLabel = careerStart.toLocaleString('en-US', { month: 'short', year: 'numeric' });
const roleCount = roles.length;
const orgCount = new Set(roles.map((r) => r.org)).size;
---

<section id="service" class="section service">
  <div class="container">
    <p class="section-label">Clearance // service record</p>
    <p class="status mono"><span class="dot" aria-hidden="true"></span> ACTIVE DUTY · Security Researcher at Microsoft (MDVM)</p>

    <div class="tenure" aria-label={`${expDisplay} years of experience since ${startLabel}`}>
      <div class="tnum mono" aria-hidden="true">
        <span class="big" data-countup={expDisplay}>{expDisplay}</span>
        <span class="unit">yrs</span>
      </div>
      <div class="tmeta mono">
        <span class="tlead">TIME IN FIELD</span>
        <span class="tsub">since {startLabel} · {roleCount} roles across {orgCount} orgs</span>
      </div>
    </div>

    <div class="orgs">
      <article class="org featured">
        <div class="logo" aria-hidden="true">
          <svg viewBox="0 0 100 100" role="img" aria-label="Microsoft">
            <rect x="4" y="4" width="42" height="42" fill="#F25022"></rect>
            <rect x="54" y="4" width="42" height="42" fill="#7FBA00"></rect>
            <rect x="4" y="54" width="42" height="42" fill="#00A4EF"></rect>
            <rect x="54" y="54" width="42" height="42" fill="#FFB900"></rect>
          </svg>
        </div>
        <div class="meta">
          <div class="orgtop">
            <h3>Microsoft</h3>
            <span class="badge mono">CURRENT</span>
          </div>
          <p class="role">Security Researcher · Defender Vulnerability Management (MDVM)</p>
          <p class="dt mono">Jun 2025 &ndash; Present · Hyderabad, India</p>
          <p class="prev mono">Prior: Security Researcher Intern · May 2024 &ndash; Jul 2024</p>
        </div>
      </article>

      <article class="org">
        <div class="logo" aria-hidden="true">
          <svg viewBox="0 0 100 100" role="img" aria-label="Hacker4Justice">
            <path d="M50 7 L87 22 V49 C87 73 71 89 50 96 C29 89 13 73 13 49 V22 Z" fill="none" stroke="#7dcfff" stroke-width="4" stroke-linejoin="round"></path>
            <text x="50" y="59" text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="24" font-weight="700" fill="#7dcfff">H4J</text>
          </svg>
        </div>
        <div class="meta">
          <div class="orgtop">
            <h3>Hacker4Justice</h3>
            <span class="badge alt mono">OSINT</span>
          </div>
          <p class="role">Volunteer OSINT Investigator</p>
          <p class="dt mono">Jun 2025 &ndash; Jun 2026 · Remote</p>
          <p class="prev mono">Foreign law-enforcement casework support</p>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  function initExpCount() {
    document.querySelectorAll<HTMLElement>('[data-countup]').forEach((el) => {
      if (el.dataset.done) return;
      const target = parseFloat(el.dataset.countup || '0');
      if (!Number.isFinite(target)) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        el.dataset.done = '1';
        return;
      }
      const io = new IntersectionObserver((entries, obs) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          obs.disconnect();
          el.dataset.done = '1';
          const t0 = performance.now();
          const dur = 1100;
          const tick = (t: number) => {
            const p = Math.min(1, (t - t0) / dur);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = (target * eased).toFixed(1);
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = target.toFixed(1);
          };
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.5 });
      io.observe(el);
    });
  }

  initExpCount();
  document.addEventListener('astro:page-load', initExpCount);
</script>

<style>
  .status { display: flex; align-items: center; gap: 10px; color: var(--cyan); font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 24px; }
  .status .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--cyan); box-shadow: 0 0 10px var(--cyan); animation: svc-pulse 2s infinite; }
  @keyframes svc-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

  .tenure {
    display: flex; align-items: center; gap: 20px; position: relative; overflow: hidden;
    padding: 16px 22px; margin-bottom: 26px; border: 1px solid var(--border); border-radius: 4px;
    background: linear-gradient(90deg, rgba(125, 207, 255, 0.07), rgba(31, 35, 53, 0.25));
  }
  .tenure::before, .tenure::after { content: ''; position: absolute; top: -1px; width: 12px; height: 12px; border-top: 2px solid var(--cyan); }
  .tenure::before { left: -1px; border-left: 2px solid var(--cyan); }
  .tenure::after { right: -1px; border-right: 2px solid var(--cyan); }
  .tnum { flex: none; display: flex; align-items: baseline; gap: 5px; }
  .tnum .big { font-size: 2.7rem; font-weight: 700; line-height: 1; color: var(--cyan); text-shadow: 0 0 20px rgba(125, 207, 255, 0.45); font-variant-numeric: tabular-nums; }
  .tnum .unit { font-size: 1rem; color: var(--muted); }
  .tmeta { display: flex; flex-direction: column; gap: 5px; min-width: 0; }
  .tmeta .tlead { font-size: 0.7rem; letter-spacing: 0.18em; color: var(--cyan); }
  .tmeta .tsub { font-size: 0.82rem; color: var(--muted); }
  @media (max-width: 520px) { .tenure { gap: 14px; padding: 14px 16px; } .tnum .big { font-size: 2.1rem; } }

  .orgs { display: grid; grid-template-columns: 1.4fr 1fr; gap: 16px; }
  .org {
    position: relative; display: flex; gap: 20px; align-items: flex-start;
    padding: 22px; border: 1px solid var(--border); border-radius: 4px;
    background: rgba(31, 35, 53, 0.5); transition: border-color 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .org::before { content: ''; position: absolute; top: -1px; left: -1px; width: 12px; height: 12px; border-top: 2px solid var(--cyan); border-left: 2px solid var(--cyan); }
  .org.featured { border-color: rgba(125, 207, 255, 0.5); box-shadow: 0 0 26px rgba(125, 207, 255, 0.12); background: linear-gradient(180deg, rgba(31, 35, 53, 0.75), rgba(26, 27, 38, 0.6)); }

  .logo { flex: none; width: 66px; height: 66px; display: grid; place-items: center; border: 1px solid var(--border); border-radius: 8px; background: #0f1017; padding: 11px; }
  .logo svg { width: 100%; height: 100%; display: block; }

  .meta { min-width: 0; }
  .orgtop { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .orgtop h3 { font-size: 1.3rem; color: var(--fg); }
  .badge { font-size: 0.6rem; letter-spacing: 0.14em; font-weight: 700; color: #0d1017; background: var(--cyan); border-radius: 4px; padding: 3px 8px; }
  .badge.alt { background: var(--purple); }
  .role { color: var(--fg); margin-top: 9px; font-size: 0.98rem; }
  .dt { color: var(--muted); font-size: 0.8rem; margin-top: 6px; }
  .prev { color: var(--muted); font-size: 0.76rem; margin-top: 12px; padding-top: 10px; border-top: 1px dashed var(--border); }

  @media (max-width: 820px) { .orgs { grid-template-columns: 1fr; } }
</style>
