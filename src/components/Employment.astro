---
// Employment / service record — a HUD "hall of fame" with employer logos.
// Roles, dates, and text come from src/data/resume.json (single source of
// truth). Regenerate it from the résumé PDF with `npm run parse:resume`.
import { resume, type WorkRole } from '@/data/resume';
import OrgCard from './OrgCard.astro';

// Official (paid) work vs volunteer roles.
const officialWork = resume.work.filter((w) => !w.volunteer);
const volunteerWork = resume.work.filter((w) => w.volunteer);

// Time actually in roles: merge official role date ranges (month granularity) and
// sum them, so the gaps between the early internships don't inflate the figure.
const monthIndex = (ym: string) => {
  const [y, m] = ym.split('-').map(Number);
  return y * 12 + (m - 1);
};
const nowIndex = new Date().getFullYear() * 12 + new Date().getMonth();
const intervals = officialWork
  .map((w) => ({ start: monthIndex(w.start), end: w.end ? monthIndex(w.end) : nowIndex }))
  .sort((a, b) => a.start - b.start);
let monthsWorked = 0;
let blockStart = -1;
let blockEnd = -2;
for (const iv of intervals) {
  if (iv.start > blockEnd + 1) {
    if (blockStart >= 0) monthsWorked += blockEnd - blockStart + 1;
    blockStart = iv.start;
    blockEnd = iv.end;
  } else {
    blockEnd = Math.max(blockEnd, iv.end);
  }
}
if (blockStart >= 0) monthsWorked += blockEnd - blockStart + 1;
const expDisplay = (monthsWorked / 12).toFixed(1);
const roleCount = officialWork.length;

// Group a role list by employer (first-seen order); an employer with a current role leads.
function groupByOrg(list: WorkRole[]) {
  return [...new Set(list.map((w) => w.org))].map((org) => {
    const roles = list.filter((w) => w.org === org);
    return {
      org,
      roles,
      featured: roles.some((r) => r.end === null),
      logo: roles.find((r) => r.logo)?.logo ?? null,
    };
  });
}
const orgs = groupByOrg(officialWork);
const orgCount = orgs.length;
const volunteerOrgs = groupByOrg(volunteerWork);

// Status line, derived from the current official role.
const current = officialWork.find((w) => w.end === null);
const currentTag = current?.blurb?.match(/\(([^)]+)\)/)?.[1] ?? null;
const statusLine = current
  ? `${current.title} at ${current.org}${currentTag ? ` (${currentTag})` : ''}`
  : 'Open to work';
---

<section id="service" class="section service">
  <div class="container">
    <p class="section-label">Clearance // service record</p>
    <p class="status mono"><span class="dot" aria-hidden="true"></span> ACTIVE DUTY · {statusLine}</p>

    <div class="tenure" aria-label={`${expDisplay} years of hands-on experience across ${roleCount} roles`}>
      <div class="tnum mono" aria-hidden="true">
        <span class="big" data-countup={expDisplay}>{expDisplay}</span>
        <span class="unit">yrs</span>
      </div>
      <div class="tmeta mono">
        <span class="tlead">TIME IN FIELD</span>
        <span class="tsub">{roleCount} roles across {orgCount} orgs</span>
      </div>
    </div>

    <div class="orgs">
      {orgs.map((o) => <OrgCard {...o} />)}
    </div>

    {
      volunteerOrgs.length > 0 && (
        <>
          <p class="subhead mono">Volunteer</p>
          <div class="orgs">
            {volunteerOrgs.map((o) => <OrgCard {...o} />)}
          </div>
        </>
      )
    }
  </div>
</section>

<script>
  function initExpCount() {
    document.querySelectorAll<HTMLElement>('[data-countup]').forEach((el) => {
      if (el.dataset.done) return;
      const target = parseFloat(el.dataset.countup || '0');
      if (!Number.isFinite(target)) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        el.dataset.done = '1';
        return;
      }
      const io = new IntersectionObserver((entries, obs) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          obs.disconnect();
          el.dataset.done = '1';
          const t0 = performance.now();
          const dur = 1100;
          const tick = (t: number) => {
            const p = Math.min(1, (t - t0) / dur);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = (target * eased).toFixed(1);
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = target.toFixed(1);
          };
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.5 });
      io.observe(el);
    });
  }

  initExpCount();
  document.addEventListener('astro:page-load', initExpCount);
</script>

<style>
  .status { display: flex; align-items: center; gap: 10px; color: var(--cyan); font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 24px; }
  .status .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--cyan); box-shadow: 0 0 10px var(--cyan); animation: svc-pulse 2s infinite; }
  @keyframes svc-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

  .tenure {
    display: flex; align-items: center; gap: 20px; position: relative; overflow: hidden;
    padding: 16px 22px; margin-bottom: 26px; border: 1px solid var(--border); border-radius: 4px;
    background: linear-gradient(90deg, rgba(125, 207, 255, 0.07), rgba(31, 35, 53, 0.25));
  }
  .tenure::before, .tenure::after { content: ''; position: absolute; top: -1px; width: 12px; height: 12px; border-top: 2px solid var(--cyan); }
  .tenure::before { left: -1px; border-left: 2px solid var(--cyan); }
  .tenure::after { right: -1px; border-right: 2px solid var(--cyan); }
  .tnum { flex: none; display: flex; align-items: baseline; gap: 5px; }
  .tnum .big { font-size: 2.7rem; font-weight: 700; line-height: 1; color: var(--cyan); text-shadow: 0 0 20px rgba(125, 207, 255, 0.45); font-variant-numeric: tabular-nums; }
  .tnum .unit { font-size: 1rem; color: var(--muted); }
  .tmeta { display: flex; flex-direction: column; gap: 5px; min-width: 0; }
  .tmeta .tlead { font-size: 0.7rem; letter-spacing: 0.18em; color: var(--cyan); }
  .tmeta .tsub { font-size: 0.82rem; color: var(--muted); }
  @media (max-width: 520px) { .tenure { gap: 14px; padding: 14px 16px; } .tnum .big { font-size: 2.1rem; } }

  .orgs { display: grid; grid-template-columns: 1.4fr 1fr; gap: 16px; align-items: start; }

  .subhead { margin: 32px 0 14px; font-size: 0.74rem; letter-spacing: 0.14em; color: var(--muted); }
  .subhead::before { content: '\25b8 '; color: var(--cyan); }

  @media (max-width: 820px) { .orgs { grid-template-columns: 1fr; } }
</style>
