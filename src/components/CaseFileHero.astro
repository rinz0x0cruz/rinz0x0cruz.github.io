---
import LottieSkull from './LottieSkull.astro';
import { site } from '@/data/site';

const caseNo = '2026-RZ-0X0';
---

<section id="top" class="hero">
  <div class="container">
    <article class="doc">
      <header class="doc-bar">
        <p class="doc-id mono">
          CASE FILE <b>#{caseNo}</b> <span class="sep">·</span> SUBJECT: {site.handle}
        </p>
        <span class="stamp classified mono">CLASSIFIED // OSINT</span>
      </header>

      <div class="doc-body">
        <div class="subject">
          <div class="mug">
            <LottieSkull size={140} />
            <span class="mug-cap mono">BIOMETRIC ID</span>
          </div>

          <div class="fields">
            <span class="stamp verified mono">SUBJECT VERIFIED</span>

            <div class="field">
              <span class="lab mono">Designation</span>
              <h1 class="val name">{site.name}</h1>
            </div>
            <div class="field">
              <span class="lab mono">Role</span>
              <span class="val">{site.role} &amp; Reverse Engineer</span>
            </div>
            <div class="field">
              <span class="lab mono">Known aliases</span>
              <span class="val mono">{site.host} · @{site.handle}</span>
            </div>
            <div class="field">
              <span class="lab mono">Last known employer</span>
              <span class="val"><span class="redact" aria-label="redacted">████████████</span> <span class="muted">— [REDACTED]</span></span>
            </div>
            {
              site.availableForWork && (
                <div class="field">
                  <span class="lab mono">Disposition</span>
                  <span class="val avail mono"><span class="dot" aria-hidden="true" /> {site.availabilityNote}</span>
                </div>
              )
            }

            <div class="cta">
              <a class="btn btn-primary" href="#work">Review exhibits</a>
              <a class="btn" href={site.resumeRequest}>Request résumé</a>
              <button class="btn" type="button" data-open-terminal>./terminal</button>
            </div>
          </div>
        </div>

        <p class="brief mono">
          <span class="brief-lab">SUMMARY //</span>
          I triage CVEs, reverse-engineer malware, and build small, sharp tools that
          turn raw threat data into readable intelligence.
        </p>
      </div>
    </article>
  </div>
</section>

<style>
  .hero { padding-top: clamp(26px, 5vw, 44px); padding-bottom: clamp(8px, 2vw, 20px); }

  .doc {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--bg-card), #191b26);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .doc-bar {
    display: flex; align-items: center; justify-content: space-between; gap: 12px 16px; flex-wrap: wrap;
    padding: 13px 22px;
    border-bottom: 1px solid var(--border);
    background: repeating-linear-gradient(45deg, rgba(224, 175, 104, 0.06) 0 12px, transparent 12px 24px);
  }
  .doc-id { font-size: 0.8rem; letter-spacing: 0.1em; color: var(--fg); }
  .doc-id b { color: var(--cyan); font-weight: 700; }
  .doc-id .sep { color: var(--muted); margin: 0 4px; }

  .stamp {
    font-size: 0.68rem; letter-spacing: 0.22em; font-weight: 700; white-space: nowrap;
    border: 2px solid currentColor; border-radius: 6px; padding: 5px 11px;
  }
  .stamp.classified { color: var(--red); transform: rotate(-2deg); }
  .stamp.verified {
    color: var(--cyan); position: absolute; top: 2px; right: 0;
    transform: rotate(6deg); opacity: 0.9;
  }

  .doc-body { padding: clamp(22px, 4vw, 38px); }

  .subject { display: flex; gap: clamp(24px, 4vw, 40px); align-items: flex-start; }
  .mug {
    flex: none; width: 176px; padding: 16px 16px 10px;
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    background: repeating-linear-gradient(45deg, #12141f 0 9px, #15172099 9px 18px);
    display: grid; place-items: center; gap: 8px;
  }
  .mug-cap { font-size: 0.62rem; letter-spacing: 0.2em; color: var(--muted); }

  .fields { flex: 1; position: relative; min-width: 0; }
  .field { margin-bottom: 14px; }
  .field .lab {
    display: block; font-size: 0.66rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--muted); margin-bottom: 3px;
  }
  .field .val { font-size: 1.02rem; color: var(--fg); }
  h1.val.name {
    font-size: clamp(1.9rem, 4.5vw, 2.6rem);
    font-weight: 800; letter-spacing: -0.02em; line-height: 1.05;
    background: linear-gradient(92deg, var(--fg), var(--blue) 75%, var(--purple));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .redact {
    background: var(--fg); color: transparent; border-radius: 2px;
    padding: 0 0.35em; user-select: none;
  }
  .avail { display: inline-flex; align-items: center; gap: 9px; color: var(--cyan); }
  .avail .dot {
    width: 9px; height: 9px; border-radius: 50%; background: var(--cyan);
    box-shadow: 0 0 0 0 rgba(125, 207, 255, 0.6); animation: cf-pulse 2s infinite;
  }
  @keyframes cf-pulse {
    70% { box-shadow: 0 0 0 9px rgba(125, 207, 255, 0); }
    100% { box-shadow: 0 0 0 0 rgba(125, 207, 255, 0); }
  }

  .cta { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 22px; }

  .brief {
    margin-top: 26px; padding-top: 18px; border-top: 1px dashed var(--border);
    color: var(--fg-dim, var(--fg)); font-size: 0.92rem; line-height: 1.7; max-width: 78ch;
  }
  .brief-lab { color: var(--yellow); letter-spacing: 0.14em; margin-right: 6px; }

  @media (max-width: 620px) {
    .subject { flex-direction: column; align-items: center; text-align: left; }
    .mug { width: 100%; max-width: 260px; }
    .fields { width: 100%; }
    .stamp.verified { position: static; display: inline-block; transform: none; margin-bottom: 14px; }
  }
</style>
