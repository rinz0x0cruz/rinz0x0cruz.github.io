---
import Emblem from './Emblem.astro';
import { site } from '@/data/site';
import { projects } from '@/data/projects';
import { getCollection } from 'astro:content';
import { formatDate, isoDate } from '@/utils/format';

const featured = projects.find((p) => p.featured) ?? projects[0];

const writeups = (await getCollection('writeups'))
  .filter((w) => !w.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const now = [
  'running a malware-analysis lab + SIEM',
  'CVE triage & tuning detections',
  'building the exploitrank threat board',
];
---

<section id="top" class="hero">
  <div class="container bento">
    <div class="card c-name">
      <p class="kicker mono">// security researcher</p>
      <h1>{site.name}</h1>
      <p class="role mono">{site.role}<span class="h"> · @{site.handle}</span></p>
      <p class="ol">
        I triage CVEs, reverse-engineer malware, and build small, sharp tools that
        make threat intel legible.
      </p>
      <div class="cta">
        <a class="btn btn-primary" href="#work">View work</a>
        <a class="btn" href={site.resumeRequest}>Request résumé</a>
        <button class="btn" type="button" data-open-terminal>./terminal</button>
      </div>
    </div>

    <div class="card c-disc" aria-hidden="true">
      <Emblem size={148} id="bento-emblem" />
    </div>

    {
      site.availableForWork && (
        <div class="card c-avail">
          <p class="kicker mono">status</p>
          <p class="avail mono">
            <span class="dot" aria-hidden="true" />
            {site.availabilityNote}
          </p>
        </div>
      )
    }

    <div class="card c-now">
      <p class="kicker mono">now</p>
      <ul>
        {now.map((n) => <li><span class="m" aria-hidden="true">▸</span> {n}</li>)}
      </ul>
    </div>

    <a class="card c-featured" href={featured.links.live ?? featured.links.repo}>
      <p class="kicker mono">★ featured</p>
      <p class="pn mono">{featured.name}</p>
      <p class="pt mono">{featured.tagline}</p>
      <p class="pd">{featured.description}</p>
      <div class="chips">
        <span class="chip">{featured.stack[0]}</span>
        {featured.links.live && <span class="chip live">● live board</span>}
      </div>
    </a>

    <div class="card c-stats">
      <p class="kicker mono">shipping</p>
      <p class="num">{projects.length}</p>
      <p class="sub mono">open-source security &amp; dev tools</p>
    </div>

    <div class="card c-socs">
      <p class="kicker mono">contact</p>
      <ul>
        {
          site.socials.map((s) => (
            <li>
              <a href={s.url} target={s.icon === 'email' ? undefined : '_blank'} rel="noopener">
                {s.name.toLowerCase()} <span class="h" aria-hidden="true">↗</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    {
      writeups.length > 0 && (
        <div class="card c-writ">
          <p class="kicker mono">writeups</p>
          {writeups.map((w) => (
            <a class="wrow" href={`/writeups/${w.id}`}>
              <time class="dt mono" datetime={isoDate(w.data.date)}>
                {formatDate(w.data.date)}
              </time>
              <span class="wt">{w.data.title}</span>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .hero { padding-top: clamp(28px, 5vw, 44px); padding-bottom: clamp(20px, 4vw, 40px); }
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    grid-auto-rows: minmax(118px, auto);
  }
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 24px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  a.card { color: var(--fg); }
  a.card:hover { border-color: var(--blue); transform: translateY(-3px); }
  .kicker {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
  }

  .c-name { grid-column: span 2; grid-row: span 2; display: flex; flex-direction: column; justify-content: center; }
  .c-name h1 {
    font-size: clamp(2.2rem, 4.6vw, 3.1rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.02;
    margin: 10px 0 0;
    background: linear-gradient(92deg, var(--fg), var(--blue) 70%, var(--purple));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .c-name .role { margin-top: 8px; color: var(--fg); }
  .c-name .role .h { color: var(--purple); }
  .c-name .ol { color: var(--muted); margin-top: 12px; max-width: 44ch; }
  .c-name .cta { margin-top: 22px; display: flex; gap: 10px; flex-wrap: wrap; }

  .c-disc { grid-column: span 1; grid-row: span 2; display: grid; place-items: center; }

  .c-avail {
    grid-column: span 1;
    background: linear-gradient(150deg, rgba(122, 162, 247, 0.14), rgba(187, 154, 247, 0.08));
    border-color: rgba(122, 162, 247, 0.35);
    display: flex; flex-direction: column; justify-content: center;
  }
  .c-avail .avail { display: flex; align-items: center; gap: 9px; color: var(--fg); margin-top: 10px; }
  .c-avail .dot {
    width: 9px; height: 9px; border-radius: 50%; background: var(--cyan);
    box-shadow: 0 0 0 0 rgba(125, 207, 255, 0.6); animation: bento-pulse 2s infinite;
  }
  @keyframes bento-pulse {
    70% { box-shadow: 0 0 0 9px rgba(125, 207, 255, 0); }
    100% { box-shadow: 0 0 0 0 rgba(125, 207, 255, 0); }
  }

  .c-now { grid-column: span 1; }
  .c-now ul { margin-top: 12px; list-style: none; padding: 0; }
  .c-now li { font-size: 0.85rem; margin: 8px 0; color: var(--fg); }
  .c-now .m { color: var(--cyan); }

  .c-featured { grid-column: span 2; }
  .c-featured .pn { font-weight: 700; font-size: 1.15rem; margin-top: 8px; color: var(--fg); }
  .c-featured .pt { color: var(--cyan); font-size: 0.85rem; margin-top: 2px; }
  .c-featured .pd {
    color: var(--muted); margin-top: 10px; font-size: 0.9rem; line-height: 1.55;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .chips { margin-top: 14px; display: flex; gap: 8px; flex-wrap: wrap; }
  .chip {
    font-family: var(--font-mono); font-size: 0.72rem; padding: 3px 10px;
    border-radius: 999px; border: 1px solid var(--border); color: var(--fg);
  }
  .chip.live { color: var(--cyan); border-color: rgba(125, 207, 255, 0.4); }

  .c-stats { grid-column: span 1; display: flex; flex-direction: column; justify-content: center; }
  .c-stats .num { font-size: 2.6rem; font-weight: 800; color: var(--fg); margin-top: 6px; letter-spacing: -0.02em; line-height: 1; }
  .c-stats .sub { font-size: 0.74rem; color: var(--muted); margin-top: 6px; }

  .c-socs { grid-column: span 1; grid-row: span 2; }
  .c-socs ul { margin-top: 12px; list-style: none; padding: 0; }
  .c-socs li a {
    display: flex; justify-content: space-between; font-family: var(--font-mono);
    font-size: 0.85rem; padding: 11px 0; border-bottom: 1px solid rgba(59, 66, 97, 0.5); color: var(--fg);
  }
  .c-socs li:last-child a { border-bottom: none; }
  .c-socs li a:hover { color: var(--cyan); }
  .c-socs .h { color: var(--muted); }

  .c-writ { grid-column: span 2; }
  .c-writ .wrow {
    display: flex; gap: 14px; align-items: baseline; padding: 11px 0;
    border-bottom: 1px solid rgba(59, 66, 97, 0.5); color: var(--fg);
  }
  .c-writ .wrow:last-child { border-bottom: none; }
  .c-writ .wrow:hover .wt { color: var(--blue); }
  .c-writ .dt { font-size: 0.74rem; color: var(--muted); white-space: nowrap; }
  .c-writ .wt { font-weight: 600; }

  @media (max-width: 900px) {
    .bento { grid-template-columns: repeat(2, 1fr); }
    .c-name, .c-featured, .c-writ { grid-column: span 2; }
    .c-name { grid-row: auto; }
    .c-disc { grid-row: auto; min-height: 200px; }
    .c-socs { grid-row: auto; }
  }
  @media (max-width: 560px) {
    .bento { grid-template-columns: 1fr; }
    .c-name, .c-featured, .c-writ, .c-avail, .c-now, .c-disc, .c-stats, .c-socs {
      grid-column: 1 / -1; grid-row: auto;
    }
  }
</style>
