---
import { site } from '@/data/site';

const links = [
  { href: '/#work', label: 'Work' },
  { href: '/#casework', label: 'Casework' },
  { href: '/#about', label: 'Experience' },
  { href: '/#trajectory', label: 'Profiles' },
  { href: '/#writing', label: 'Blogs' },
];
---

<header class="header" data-site-nav>
  <div class="container header-inner">
    <a class="identity" href="/" aria-label={`${site.name}, home`}>
      <strong>{site.name}</strong>
      <span>Security researcher</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <div class="header-actions">
      <a class="contact-link" href="/#contact">Contact</a>
      <a class="resume-link" href={site.resumeUrl} download>Résumé</a>
      <button class="theme-button" type="button" data-theme-toggle aria-label="Switch color theme" title="Switch color theme">◐</button>
      <button class="terminal-button terminal-btn" type="button" data-open-terminal aria-label="Open terminal" title="Open terminal">⌘</button>
      <details class="nav-mobile">
        <summary aria-label="Toggle menu">Menu</summary>
        <div class="nav-mobile-panel">
          {links.map((link) => <a href={link.href}>{link.label}</a>)}
          <a href={site.resumeUrl} download>Résumé</a>
          <button type="button" data-open-terminal>Terminal</button>
        </div>
      </details>
    </div>
  </div>
</header>

<script>
  function initPortfolioHeader() {
    const root = document.documentElement;
    const param = new URLSearchParams(window.location.search).get('scoutTheme');
    const setThemeColor = (theme: string) => {
      const meta = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
      if (meta) meta.content = theme === 'dark' ? '#20201f' : '#f7f4ef';
    };

    if (param === 'light' || param === 'dark') root.dataset.theme = param;
    else {
      try {
        const saved = localStorage.getItem('portfolio-theme');
        if (saved === 'light' || saved === 'dark') root.dataset.theme = saved;
      } catch {}
    }
    setThemeColor(root.dataset.theme ?? 'light');

    document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((button) => {
      if (button.dataset.bound) return;
      button.dataset.bound = 'true';
      button.addEventListener('click', () => {
        const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        setThemeColor(next);
        try { localStorage.setItem('portfolio-theme', next); } catch {}
      });
    });

    document.querySelectorAll<HTMLDetailsElement>('.nav-mobile').forEach((menu) => {
      if (menu.dataset.bound) return;
      menu.dataset.bound = 'true';
      menu.querySelectorAll('a, button').forEach((item) => item.addEventListener('click', () => { menu.open = false; }));
    });
  }
  initPortfolioHeader();
  document.addEventListener('astro:page-load', initPortfolioHeader);
</script>

<style>
  .header { position: sticky; top: 0; z-index: 100; height: var(--nav-h); border-bottom: 1px solid var(--cp-border); background: var(--cp-overlay); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px); }
  .header-inner { width: 100%; max-width: none; height: 100%; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 24px; padding-inline: clamp(20px, 3vw, 40px); }
  .identity { display: flex; align-items: baseline; gap: 10px; color: var(--cp-text); white-space: nowrap; }
  .identity:hover { color: var(--cp-text); }
  .identity strong { font-size: .96rem; }
  .identity span { color: var(--cp-text-muted); font-size: .78rem; }
  .nav-links { display: flex; align-items: center; gap: 24px; }
  .nav-links a { color: var(--cp-text-muted); font-size: .82rem; font-weight: 650; }
  .nav-links a:hover,
  .nav-links a:focus-visible { color: var(--cp-accent); }
  .header-actions { display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
  .contact-link { display: inline-flex; min-height: 34px; align-items: center; border: 1px solid var(--cp-accent); border-radius: 999px; background: var(--cp-accent); color: var(--cp-accent-fg); padding: 6px 13px; font-size: .76rem; font-weight: 700; box-shadow: var(--card-shadow); transition: background 160ms var(--ease), color 160ms var(--ease), transform 160ms var(--ease); }
  .contact-link:hover { transform: translateY(-1px); background: var(--cp-accent-hover); color: var(--cp-accent-fg); }
  .resume-link { color: var(--cp-text); font-size: .78rem; font-weight: 700; }
  .resume-link:hover { color: var(--cp-accent); }
  .theme-button,
  .terminal-button,
  .nav-mobile summary { display: grid; width: 34px; height: 34px; place-items: center; border: 1px solid var(--cp-border); border-radius: 50%; background: var(--cp-surface); color: var(--cp-text); box-shadow: var(--card-shadow); cursor: pointer; }
  .theme-button:hover,
  .terminal-button:hover { border-color: var(--cp-accent); color: var(--cp-accent); }
  .nav-mobile { display: none; position: relative; }
  .nav-mobile summary { width: auto; min-width: 56px; border-radius: 999px; padding-inline: 11px; list-style: none; font-size: .76rem; font-weight: 700; }
  .nav-mobile summary::-webkit-details-marker { display: none; }
  .nav-mobile-panel { position: absolute; top: 44px; right: 0; display: grid; min-width: 210px; gap: 3px; border: 1px solid var(--cp-border-strong); border-radius: 8px; background: var(--cp-surface); padding: 8px; box-shadow: var(--cp-shadow); }
  .nav-mobile-panel a,
  .nav-mobile-panel button { border: 0; border-radius: 6px; background: transparent; color: var(--cp-text); padding: 10px; text-align: left; cursor: pointer; font-size: 0.75rem; }
  .nav-mobile-panel a:hover,
  .nav-mobile-panel button:hover { background: var(--cp-accent-soft); color: var(--cp-accent); }
  @media (max-width: 820px) { .header-inner { grid-template-columns: 1fr auto; } .nav-links, .resume-link, .terminal-button { display: none; } .nav-mobile { display: block; } }
  @media (max-width: 420px) { .identity span { display: none; } }
</style>