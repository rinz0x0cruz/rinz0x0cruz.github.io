---
interface Props {
  size?: number;
  class?: string;
}
const { size = 168, class: className } = Astro.props;
const h = Math.round((size * 210) / 200);
---

<div
  class:list={['lottie-skull', className]}
  style={`width:${size}px;height:${h}px`}
  data-lottie-skull
  role="img"
  aria-label="animated skull emblem"
>
</div>

<script>
  // @ts-ignore - the light build ships no bundled types
  import lottie from 'lottie-web/build/player/lottie_light';
  import animationData from '../assets/skull.json';

  function mount() {
    document.querySelectorAll<HTMLElement>('[data-lottie-skull]').forEach((el) => {
      if (el.dataset.mounted) return;
      el.dataset.mounted = '1';
      lottie.loadAnimation({
        container: el,
        renderer: 'svg',
        loop: true,
        autoplay: !window.matchMedia('(prefers-reduced-motion: reduce)').matches,
        animationData,
      });
    });
  }

  mount();
  document.addEventListener('astro:page-load', mount);
</script>

<style>
  .lottie-skull {
    filter: drop-shadow(0 0 16px rgba(122, 162, 247, 0.3));
    animation: skull-float 5s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes skull-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lottie-skull { animation: none; }
  }
</style>
