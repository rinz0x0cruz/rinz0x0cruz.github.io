---
import { analyticsCampaignSources } from '@/data/analytics';

const configuredEndpoint = import.meta.env.PUBLIC_ANALYTICS_ENDPOINT?.trim();
const configuredEngagement = import.meta.env.PUBLIC_ANALYTICS_ENGAGEMENT?.trim().toLowerCase();
const configuredContext = import.meta.env.PUBLIC_ANALYTICS_CONTEXT?.trim().toLowerCase();
let endpoint: string | undefined;

if (configuredEndpoint) {
  const parsed = new URL(configuredEndpoint);
  if (
    parsed.protocol !== 'https:' ||
    parsed.username ||
    parsed.password ||
    parsed.search ||
    parsed.hash ||
    !parsed.pathname.endsWith('/api/event')
  ) {
    throw new Error('PUBLIC_ANALYTICS_ENDPOINT must be an HTTPS /api/event URL without credentials, query, or fragment.');
  }
  endpoint = parsed.href;
}

if (configuredEngagement && !['true', 'false'].includes(configuredEngagement)) {
  throw new Error('PUBLIC_ANALYTICS_ENGAGEMENT must be true or false when configured.');
}
if (configuredContext && !['true', 'false'].includes(configuredContext)) {
  throw new Error('PUBLIC_ANALYTICS_CONTEXT must be true or false when configured.');
}

const enabled = import.meta.env.PROD && Boolean(endpoint);
const engagementEnabled = enabled && configuredEngagement === 'true';
const contextEnabled = enabled && configuredContext === 'true';
---

{enabled && (
  <script is:inline define:vars={{ endpoint, engagementEnabled, contextEnabled, analyticsCampaignSources }} data-analytics-provider="owned">
    (() => {
      const privacyRequested =
        navigator.globalPrivacyControl === true ||
        navigator.doNotTrack === '1' ||
        window.doNotTrack === '1';
      if (privacyRequested) return;

      const allowedEvents = new Set([
        'contact_click',
        'resume_download',
        'project_live',
        'project_source',
        'work_detail_open',
        'blog_open',
      ]);

      if (window.__portfolioAnalyticsBound) return;
      window.__portfolioAnalyticsBound = true;

      const route = window.location.pathname;
      let campaignSource = '';
      if (engagementEnabled) {
        const currentUrl = new URL(window.location.href);
        const candidate = currentUrl.searchParams.get('src');
        if (candidate !== null) {
          currentUrl.searchParams.delete('src');
          window.history.replaceState(window.history.state, '', `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`);
        }
        if (candidate && analyticsCampaignSources.includes(candidate)) campaignSource = candidate;
      }
      const referrerHost = (() => {
        if (!document.referrer) return '';
        try {
          const referrer = new URL(document.referrer);
          return referrer.hostname === window.location.hostname ? '' : referrer.hostname;
        } catch {
          return '';
        }
      })();

      const send = (name, contentId, placement, includeReferrer = true) => {
        const payload = { name, route };
        if (contentId && placement) {
          payload.content_id = contentId;
          payload.placement = placement;
        }
        if (includeReferrer && referrerHost) payload.referrer_host = referrerHost;
        const body = JSON.stringify(payload);
        if (navigator.sendBeacon?.(endpoint, body)) return;
        void fetch(endpoint, {
          method: 'POST',
          body,
          credentials: 'omit',
          keepalive: true,
          mode: 'cors',
          headers: { 'content-type': 'text/plain;charset=UTF-8' },
        }).catch(() => {});
      };

      let contextSent = false;
      const sendContext = () => {
        if (!contextEnabled || contextSent) return;
        contextSent = true;
        send('context_visit', 'context', 'granted', false);
      };
      const contextChoice = document.cookie
        .split(';')
        .map((entry) => entry.trim())
        .find((entry) => entry.startsWith('pa_context_consent='))
        ?.slice('pa_context_consent='.length);
      if (contextChoice === 'granted') sendContext();
      document.addEventListener('portfolio:analytics-consent', (event) => {
        if (event.detail?.granted === true) sendContext();
      });

      send('pageview');
      if (campaignSource) send('campaign_visit', campaignSource, 'landing', false);

      const campaignActions = {
        contact_click: 'contact',
        resume_download: 'resume',
        project_live: 'live',
        project_source: 'source',
        work_detail_open: 'deep_dive',
        blog_open: 'blog',
      };

      const track = (event) => {
        if (event.type === 'auxclick' && event.button !== 1) return;
        const target = event.target instanceof Element
          ? event.target.closest('[data-analytics-event]')
          : null;
        if (!target) return;
        const name = target.dataset.analyticsEvent;
        const contentId = target.dataset.analyticsId;
        const placement = target.dataset.analyticsPlacement;
        if (!allowedEvents.has(name) || !contentId || !placement) return;
        send(name, contentId, placement);
        const campaignAction = campaignActions[name];
        if (campaignSource && campaignAction) send('campaign_action', campaignSource, campaignAction, false);
      };

      document.addEventListener('click', track);
      document.addEventListener('auxclick', track);

      if (!engagementEnabled) return;

      const setupEngagement = () => {
        const milestones = [
          [3000, '3s'],
          [10000, '10s'],
          [30000, '30s'],
        ];
        const states = new Map();
        let lastTick = performance.now();
        let lastActivity = Date.now();
        let progressPending = false;

        const resetClock = () => { lastTick = performance.now(); };
        const recordActivity = () => {
          resetClock();
          lastActivity = Date.now();
        };
        const handleVisibility = () => {
          if (document.hidden) resetClock();
          else recordActivity();
        };
        const foreground = () =>
          !document.hidden && document.hasFocus() && Date.now() - lastActivity < 60000;

        document.querySelectorAll('[data-analytics-section]').forEach((element) => {
          const sectionId = element.dataset.analyticsSection;
          if (sectionId) states.set(element, { sectionId, visible: false, elapsed: 0, sent: new Set() });
        });

        let observer;
        if ('IntersectionObserver' in window) {
          observer = new IntersectionObserver((entries) => {
            resetClock();
            entries.forEach((entry) => {
              const state = states.get(entry.target);
              if (state) state.visible = entry.isIntersecting;
            });
          }, { rootMargin: '-25% 0px -25% 0px', threshold: 0.01 });
          states.forEach((_state, element) => observer.observe(element));
        }

        if (states.size) {
          window.setInterval(() => {
            const now = performance.now();
            const delta = now - lastTick;
            lastTick = now;
            if (!foreground()) return;
            states.forEach((state) => {
              if (!state.visible) return;
              state.elapsed += delta;
              milestones.forEach(([threshold, placement]) => {
                if (state.elapsed < threshold || state.sent.has(placement)) return;
                state.sent.add(placement);
                send('section_engaged', state.sectionId, placement, false);
                if (campaignSource && placement === '10s') {
                  send('campaign_attention', campaignSource, state.sectionId, false);
                }
              });
            });
          }, 1000);
        }

        const progressSent = new Set();
        const article = document.querySelector('[data-analytics-article]');
        const measureArticle = () => {
          progressPending = false;
          if (!article || !foreground()) return;
          const contentId = article.dataset.analyticsContentId;
          if (!contentId) return;
          const bounds = article.getBoundingClientRect();
          const readingLine = window.innerHeight * 0.72;
          const progress = Math.max(0, Math.min(1, (readingLine - bounds.top) / Math.max(1, bounds.height)));
          [[0.25, 'p25'], [0.5, 'p50'], [0.9, 'p90']].forEach(([threshold, placement]) => {
            if (progress < threshold || progressSent.has(placement)) return;
            progressSent.add(placement);
            send('article_progress', contentId, placement, false);
          });
        };
        const scheduleArticleMeasure = () => {
          recordActivity();
          if (progressPending) return;
          progressPending = true;
          requestAnimationFrame(measureArticle);
        };

        const sourceLedgers = new WeakSet();
        const trackLedger = (event) => {
          const ledger = event.target;
          if (!(ledger instanceof HTMLDetailsElement) || !ledger.open || !ledger.matches('[data-analytics-source-ledger]') || sourceLedgers.has(ledger)) return;
          const contentId = ledger.dataset.analyticsContentId;
          if (!contentId) return;
          sourceLedgers.add(ledger);
          send('content_interaction', contentId, 'source_ledger_open', false);
        };

        const interactionSent = new Set();
        const trackCustomInteraction = (event) => {
          const detail = event.detail;
          if (!detail || detail.name !== 'content_interaction') return;
          if (!/^[a-z0-9_-]{1,80}$/.test(detail.contentId) || !/^[a-z0-9_-]{1,80}$/.test(detail.placement)) return;
          const key = `${detail.contentId}:${detail.placement}`;
          if (interactionSent.has(key)) return;
          interactionSent.add(key);
          send('content_interaction', detail.contentId, detail.placement, false);
        };

        ['pointerdown', 'keydown', 'touchstart'].forEach((name) => window.addEventListener(name, recordActivity, { passive: true }));
        if (article) {
          window.addEventListener('scroll', scheduleArticleMeasure, { passive: true });
          window.addEventListener('resize', scheduleArticleMeasure, { passive: true });
        }
        window.addEventListener('focus', recordActivity);
        window.addEventListener('blur', resetClock);
        document.addEventListener('visibilitychange', handleVisibility);
        document.addEventListener('toggle', trackLedger, true);
        document.addEventListener('portfolio:analytics', trackCustomInteraction);
        if (article) measureArticle();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupEngagement, { once: true });
      } else {
        setupEngagement();
      }
    })();
  </script>
)}