---
import { intro } from '@/data/portfolio';
import { resume } from '@/data/resume';
import { site } from '@/data/site';
import { calculateExperience } from '@/utils/experience';

const configuredBuildDate = import.meta.env.BUILD_DATE;
const buildDate = configuredBuildDate ? new Date(`${configuredBuildDate}T00:00:00Z`) : new Date();
const experience = calculateExperience(resume.work, buildDate);
const currentRole = resume.work.find((role) => !role.volunteer && role.end === null);
const identityLinks = site.socials.filter((social) => social.featured);
---

<section id="top" class="intro" data-motion-hero data-analytics-section="top">
  <div class="intro-pattern" aria-hidden="true"></div>
  <div class="container identity-plate">
    <header class="utility-line mono">
      <span>Identity / 001</span>
      <span>{resume.basics.location}</span>
      <span class="availability">
        <i aria-hidden="true"></i>
        <span class="availability-long">{site.availabilityNote}</span>
        <span class="availability-short">Available for research work</span>
      </span>
    </header>

    <div class="name-layout">
      <aside class="monogram" aria-hidden="true">
        <strong>MS</strong>
        <span></span>
        <small class="mono">Research<br />Engineering</small>
      </aside>

      <div class="identity-copy">
        <p class="role-line mono"><span>{site.role}</span><i></i>@{site.handle}</p>
        <h1>{site.name}</h1>
        <p class="statement">{intro.statement}</p>
      </div>
    </div>

    <footer class="identity-footer">
      <dl class="proof-strip" aria-label="Professional snapshot">
        <div>
          <dt>Now</dt>
          <dd>{currentRole ? `${currentRole.title} at ${currentRole.org}` : site.role}</dd>
        </div>
        <div>
          <dt>Focus</dt>
          <dd class="focus-rotator" data-focus-rotator aria-label={intro.currentFocus.join('; ')}>
            {intro.currentFocus.map((focus, index) => (
              <span class:list={{ 'is-active': index === 0 }} aria-hidden="true">{focus}</span>
            ))}
          </dd>
        </div>
        <div>
          <dt>Experience</dt>
          <dd>{experience.yearsDisplay} years across {experience.organizationCount} organizations</dd>
        </div>
      </dl>

      <div class="identity-actions">
        <div>
          <a class="btn btn-primary" href="#work">Selected work <span aria-hidden="true">↓</span></a>
          <a class="btn" href={site.resumeUrl} download data-analytics-event="resume_download" data-analytics-id="resume" data-analytics-placement="hero">Resume</a>
        </div>
        <nav aria-label="Primary identity links">
          {identityLinks.map((social) => (
            <a href={social.url} target="_blank" rel="me noopener">{social.name} <span aria-hidden="true">↗</span></a>
          ))}
          <a href={`mailto:${site.email}`} data-analytics-event="contact_click" data-analytics-id="email" data-analytics-placement="hero">Email <span aria-hidden="true">↗</span></a>
        </nav>
      </div>
    </footer>
  </div>

  <div class="intro-pulse" aria-hidden="true"><span></span></div>
</section>

<script>
  function initFocusRotators() {
    document.querySelectorAll<HTMLElement>('[data-focus-rotator]').forEach((root) => {
      if (root.dataset.bound) return;
      root.dataset.bound = 'true';
      const items = Array.from(root.querySelectorAll<HTMLElement>('span'));
      if (items.length < 2 || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      let active = 0;
      window.setInterval(() => {
        items[active].classList.remove('is-active');
        active = (active + 1) % items.length;
        items[active].classList.add('is-active');
      }, 4200);
    });
  }

  initFocusRotators();
  document.addEventListener('astro:page-load', initFocusRotators);
</script>

<style>
  .intro {
    position: relative;
    display: grid;
    min-height: max(660px, calc(100svh - var(--nav-h) - 48px));
    align-items: center;
    overflow: hidden;
    border-bottom: 1px solid var(--cp-border-strong);
    background:
      linear-gradient(105deg, transparent 0 58%, var(--cp-accent-soft) 58% 58.2%, transparent 58.2%),
      linear-gradient(145deg, var(--cp-bg) 0%, var(--cp-bg-elevated) 70%, var(--cp-surface-soft) 100%);
    padding-block: 52px 66px;
  }
  .intro-pattern {
    position: absolute;
    inset: 0;
    opacity: .38;
    background-image:
      linear-gradient(var(--cp-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--cp-border) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(90deg, #000, transparent 72%);
    pointer-events: none;
    transform: translate3d(var(--hero-grid-x, 0), var(--hero-grid-y, 0), 0) scale(1.035);
    transition: transform 260ms ease-out;
    will-change: transform;
  }
  .identity-plate {
    position: relative;
    display: grid;
    overflow: hidden;
    border-block: 1px solid var(--cp-border-strong);
  }
  .identity-plate::before {
    content: '';
    position: absolute;
    z-index: 3;
    top: 0;
    bottom: 0;
    left: -12%;
    width: 1px;
    opacity: 0;
    background: linear-gradient(transparent, var(--cp-accent) 22% 78%, transparent);
    box-shadow: 0 0 18px var(--cp-accent);
    pointer-events: none;
    animation: plate-signal 8s 1.4s var(--ease) infinite;
  }
  .utility-line { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 20px; color: var(--cp-text-muted); padding-block: 12px; font-size: var(--type-label); text-transform: uppercase; }
  .utility-line > span:nth-child(2) { justify-self: center; }
  .availability { display: flex; justify-self: end; align-items: center; gap: 8px; }
  .availability-short { display: none; }
  .availability i { width: 7px; height: 7px; border-radius: 50%; background: var(--cp-success); box-shadow: 0 0 0 0 var(--cp-highlight); animation: availability-pulse 2.4s ease-out infinite; }
  .name-layout { display: grid; grid-template-columns: 118px minmax(0, 1fr); gap: clamp(30px, 5vw, 72px); align-items: stretch; border-top: 1px solid var(--cp-border); padding-block: clamp(42px, 6vw, 70px); }
  .monogram { display: flex; min-height: 255px; flex-direction: column; justify-content: space-between; border-right: 1px solid var(--cp-border); padding-right: 28px; transform: translate3d(calc(var(--hero-copy-x, 0px) * -.45), calc(var(--hero-copy-y, 0px) * -.45), 0); transition: transform 260ms ease-out; will-change: transform; }
  .monogram strong { color: var(--cp-accent); font-family: var(--font-display); font-size: 2.15rem; line-height: 1; }
  .monogram > span { width: 1px; flex: 1; margin: 22px 0; background: linear-gradient(var(--cp-accent), var(--cp-border)); }
  .monogram small { color: var(--cp-text-muted); font-size: .62rem; line-height: 1.5; text-transform: uppercase; }
  .identity-copy { align-self: center; max-width: 1050px; transform: translate3d(var(--hero-copy-x, 0), var(--hero-copy-y, 0), 0); transition: transform 260ms ease-out; will-change: transform; }
  .role-line { display: flex; align-items: center; gap: 11px; color: var(--cp-text-muted); font-size: .78rem; text-transform: uppercase; }
  .role-line span { color: var(--cp-accent); font-weight: 700; }
  .role-line i { width: 24px; height: 1px; background: var(--cp-border-strong); }
  h1 { margin-top: 17px; background: linear-gradient(100deg, var(--cp-text) 0 42%, var(--cp-accent) 49%, var(--cp-text) 56% 100%); background-position: 100% 50%; background-size: 260% 100%; color: transparent; font-size: 7.75rem; font-weight: 600; line-height: .84; white-space: nowrap; -webkit-background-clip: text; background-clip: text; }
  .statement { max-width: 68ch; margin-top: 25px; color: var(--cp-text-soft); font-size: 1.08rem; line-height: 1.65; }
  .identity-footer { border-top: 1px solid var(--cp-border); }
  .proof-strip { display: grid; grid-template-columns: 1.1fr 1.2fr 1fr; }
  .proof-strip > div { min-width: 0; border-right: 1px solid var(--cp-border); padding: 16px 20px 17px 0; }
  .proof-strip > div + div { padding-left: 20px; }
  .proof-strip > div:last-child { border-right: 0; }
  .proof-strip dt { color: var(--cp-accent); font-family: var(--font-mono); font-size: var(--type-label); font-weight: 700; text-transform: uppercase; }
  .proof-strip dd { margin: 6px 0 0; color: var(--cp-text); font-size: .82rem; line-height: 1.45; }
  .focus-rotator { display: grid; min-height: 1.45em; overflow: hidden; }
  .focus-rotator span { grid-area: 1 / 1; opacity: 0; transform: translateY(7px); transition: opacity 280ms var(--ease), transform 360ms var(--ease); }
  .focus-rotator span.is-active { opacity: 1; transform: none; }
  .identity-actions { display: flex; align-items: center; justify-content: space-between; gap: 24px; border-top: 1px solid var(--cp-border); padding-block: 14px; }
  .identity-actions > div,
  .identity-actions nav { display: flex; flex-wrap: wrap; gap: 9px; }
  .identity-actions nav { gap: 17px; }
  .identity-actions nav a { color: var(--cp-text-muted); font-size: var(--type-small); font-weight: 700; }
  .identity-actions nav a:hover { color: var(--cp-accent); }
  .intro-pulse { position: absolute; right: 0; bottom: 28px; left: 0; height: 1px; overflow: hidden; background: var(--cp-border); }
  .intro-pulse span { display: block; width: 22%; height: 100%; background: linear-gradient(90deg, transparent, var(--cp-accent), transparent); animation: intro-signal 6s ease-in-out infinite; }
  .utility-line { animation: intro-arrive 560ms 40ms var(--ease) both; }
  .monogram strong { animation: intro-arrive 620ms 130ms var(--ease) both; }
  .monogram > span { animation: monogram-grow 820ms 180ms var(--ease) both; transform-origin: top; }
  .monogram small { animation: intro-arrive 620ms 260ms var(--ease) both; }
  .role-line { animation: intro-arrive 620ms 180ms var(--ease) both; }
  h1 { animation: intro-name 860ms 230ms var(--ease) both, name-glint 7.5s 1.6s ease-in-out infinite; }
  .statement { animation: intro-arrive 700ms 400ms var(--ease) both; }
  .proof-strip > div { animation: intro-arrive 600ms var(--ease) both; }
  .proof-strip > div:first-child { animation-delay: 480ms; }
  .proof-strip > div:nth-child(2) { animation-delay: 560ms; }
  .proof-strip > div:nth-child(3) { animation-delay: 640ms; }
  .identity-actions { animation: intro-arrive 640ms 700ms var(--ease) both; }
  @keyframes intro-signal { from { transform: translateX(-100%); } to { transform: translateX(550%); } }
  @keyframes availability-pulse { to { box-shadow: 0 0 0 10px transparent; } }
  @keyframes plate-signal { 0%, 16% { left: -12%; opacity: 0; } 22% { opacity: .72; } 48% { left: 112%; opacity: 0; } 100% { left: 112%; opacity: 0; } }
  @keyframes intro-arrive { from { opacity: 0; transform: translateY(14px); } }
  @keyframes intro-name { from { opacity: 0; transform: translateY(24px); clip-path: inset(0 0 42% 0); } }
  @keyframes monogram-grow { from { opacity: 0; transform: scaleY(0); } }
  @keyframes name-glint { 0%, 18% { background-position: 100% 50%; } 44%, 100% { background-position: 0 50%; } }
  @media (max-width: 1100px) {
    .name-layout { grid-template-columns: 94px minmax(0, 1fr); }
    h1 { font-size: 5.5rem; }
  }
  @media (max-width: 780px) {
    .intro { min-height: 0; background: linear-gradient(160deg, var(--cp-bg), var(--cp-bg-elevated)); padding-block: 32px 42px; }
    .utility-line { grid-template-columns: 1fr auto; }
    .utility-line > span:nth-child(2) { display: none; }
    .name-layout { grid-template-columns: 1fr; gap: 18px; padding-block: 32px; }
    .monogram { min-height: 0; flex-direction: row; align-items: center; border-right: 0; padding-right: 0; }
    .monogram > span { width: auto; height: 1px; flex: 1; margin: 0 15px; background: linear-gradient(90deg, var(--cp-accent), var(--cp-border)); }
    .monogram small { text-align: right; }
    h1 { font-size: 4rem; white-space: normal; }
    .statement { margin-top: 20px; font-size: .98rem; }
    .proof-strip { grid-template-columns: 1fr; }
    .proof-strip > div,
    .proof-strip > div + div { border-right: 0; border-bottom: 1px solid var(--cp-border); padding: 11px 0 12px; }
    .identity-actions { align-items: flex-start; flex-direction: column; }
  }
  @media (max-width: 420px) {
    .availability { justify-content: flex-end; text-align: right; line-height: 1.35; }
    .availability-long { display: none; }
    .availability-short { display: inline; }
    h1 { font-size: 3.5rem; }
    .proof-strip { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .proof-strip > div:nth-child(2) { display: none; }
    .proof-strip > div,
    .proof-strip > div + div { border-right: 1px solid var(--cp-border); border-bottom: 0; padding: 12px 10px 13px 0; }
    .proof-strip > div:nth-child(3) { border-right: 0; padding-left: 12px; }
    .proof-strip dd { font-size: .74rem; }
    .identity-actions nav { gap: 14px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .intro-pattern,
    .monogram,
    .identity-copy { transform: none; transition: none; }
    .identity-plate::before,
    .utility-line,
    .monogram strong,
    .monogram > span,
    .monogram small,
    .role-line,
    h1,
    .statement,
    .proof-strip > div,
    .identity-actions,
    .availability i,
    .intro-pulse span { animation: none; }
    .focus-rotator span { display: none; transition: none; }
    .focus-rotator span:first-child { display: inline; opacity: 1; transform: none; }
    h1 { background: none; color: var(--cp-text); }
  }
</style>